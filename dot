#!/usr/bin/env bash

set -euo pipefail

# ═══════════════════════════════════════════════════════════════════════════════
# CONSTANTS & GLOBALS
# ═══════════════════════════════════════════════════════════════════════════════

readonly SCRIPT_NAME="dot"
readonly VERSION="0.1.0"
readonly DOTFILES_DIR="${HOME}/.dotfiles"
readonly HOME_DIR="${DOTFILES_DIR}/home"
readonly BREWFILE="${DOTFILES_DIR}/Brewfile"

ASSUME_YES=false

readonly RED=$'\033[0;31m'
readonly GREEN=$'\033[0;32m'
readonly YELLOW=$'\033[0;33m'
readonly BLUE=$'\033[0;34m'
readonly CYAN=$'\033[0;36m'
readonly BOLD=$'\033[1m'
readonly DIM=$'\033[2m'
readonly RESET=$'\033[0m'

# ═══════════════════════════════════════════════════════════════════════════════
# OUTPUT UTILITIES
# ═══════════════════════════════════════════════════════════════════════════════

info() {
  printf '%b\n' "${CYAN}ℹ${RESET} ${CYAN}[INFO]${RESET} $1"
}

warn() {
  printf '%b\n' "${YELLOW}⚠${RESET} ${YELLOW}[WARN]${RESET} $1">&2
}

error() {
  printf '%b\n' "${RED}✗${RESET} ${RED}[ERROR]${RESET} $1">&2
}

header() {
  printf '\n%b\n' "${BOLD}${BLUE}==>${RESET} ${BOLD}$1${RESET}"
}

step() {
  printf '%b\n' "${BOLD}${CYAN}->${RESET} $1"
}

detail() {
  printf '%b\n' "${DIM}  $1${RESET}"
}

success() {
  printf '%b\n' "${GREEN}✓${RESET} ${GREEN}[OK]${RESET} $1"
}

show_log_excerpt() {
  local log_file="$1" line_count=0
  while IFS= read -r line; do
    line_count=$((line_count + 1))
    (( line_count > 20 )) && break
    detail "$line"
  done < "$log_file"
}

# ═══════════════════════════════════════════════════════════════════════════════
# CORE UTILITIES
# ═══════════════════════════════════════════════════════════════════════════════

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

confirm() {
  local prompt="$1"
  [[ "$ASSUME_YES" == true ]] && return 0
  read -r -p "$prompt [y/N]: " response
  case "$response" in
    [yY]|[yY][eE][sS]) return 0 ;;
    *) return 1 ;;
  esac
}

require_runtime_tools() {
  local missing=() tool
  for tool in "$@"; do
    command_exists "$tool" || missing+=("$tool")
  done
  [[ ${#missing[@]} -eq 0 ]] && return 0
  error "Missing required tools: ${missing[*]}"
  error "Run 'dot init' to repair this machine state."
  exit 1
}

run_logged() {
  local stream=false
  [[ "$1" == "--stream" ]] && { stream=true; shift; }
  
  local title="$1"; shift
  local log_file exit_code
  log_file=$(mktemp)
  
  if [[ "$stream" == true ]]; then
    detail "Running: $*"
    "$@" 2>&1 | tee "$log_file"
    exit_code=${PIPESTATUS[0]}
  else
    "$@" >"$log_file" 2>&1
    exit_code=$?
  fi
  
  if [[ $exit_code -eq 0 ]]; then
    rm -f "$log_file"
    return 0
  fi
  
  error "$title failed"
  [[ -s "$log_file" ]] && { detail "Command output:"; show_log_excerpt "$log_file"; }
  rm -f "$log_file"
  return 1
}

# ═══════════════════════════════════════════════════════════════════════════════
# PACKAGE MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════

brewfile_entries() {
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line//[[:space:]]/}" ]] && continue

    if [[ "$line" =~ ^brew[[:space:]]+\"([^\"]+)\" ]]; then
      printf 'brew\t%s\n' "${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^cask[[:space:]]+\"([^\"]+)\" ]]; then
      printf 'cask\t%s\n' "${BASH_REMATCH[1]}"
    fi
  done < "$BREWFILE"
}

package_is_declared() {
  grep -qF "\"$1\"" "$BREWFILE"
}

detect_package_type() {
  local package_name="$1"
  if brew info --json=v2 --formula "$package_name" >/dev/null 2>&1; then
    printf 'brew\n'
  elif brew info --json=v2 --cask "$package_name" >/dev/null 2>&1; then
    printf 'cask\n'
  else
    printf 'brew\n'
  fi
}

append_brewfile_entry() {
  local package_type="$1" package_name="$2"
  printf '\n%s "%s"\n' "$package_type" "$package_name" >> "$BREWFILE"
}

remove_brewfile_entry() {
  local temp_file
  temp_file=$(mktemp)
  grep -vF "\"$1\"" "$BREWFILE" > "$temp_file" || true
  mv "$temp_file" "$BREWFILE"
}

write_failed_packages_report() {
  local report_dir="${DOTFILES_DIR}/.reports" report_file
  report_file="${report_dir}/failed-brew-packages-$(date +%Y%m%d_%H%M%S).txt"
  mkdir -p "$report_dir"
  printf '%s\n' "$@" > "$report_file"
  warn "Saved failed package list to $report_file"
}

install_brewfile_packages_individually() {
  local failed_packages=() installed_count=0 kind package

  while IFS=$'\t' read -r kind package; do
    [[ -n "$kind" && -n "$package" ]] || continue
    step "Installing $kind package: $package"

    if [[ "$kind" == "cask" ]]; then
      brew install --cask "$package" && ((installed_count++)) || { warn "Failed to install cask: $package"; failed_packages+=("cask:$package"); }
    else
      brew install "$package" && ((installed_count++)) || { warn "Failed to install brew package: $package"; failed_packages+=("brew:$package"); }
    fi
  done < <(brewfile_entries)

  if [[ ${#failed_packages[@]} -gt 0 ]]; then
    warn "Failed packages: ${failed_packages[*]}"
    write_failed_packages_report "${failed_packages[@]}"
    error "Installed $installed_count package(s); ${#failed_packages[@]} failed"
    return 1
  fi

  success "Installed $installed_count package(s)"
}

run_brew_bundle() {
  step "Applying Brewfile"
  detail "$BREWFILE"

  if brew bundle --file "$BREWFILE"; then
    success "Brewfile applied"
    return 0
  fi

  warn "brew bundle failed; retrying packages individually"
  install_brewfile_packages_individually
}

report_package_status() {
  local missing_brew=() missing_cask=() installed_brew=() installed_cask=()
  local installed_formulas installed_casks kind package

  installed_formulas=$(brew list --formula 2>/dev/null || true)
  installed_casks=$(brew list --cask 2>/dev/null || true)

  while IFS=$'\t' read -r kind package; do
    [[ -n "$kind" && -n "$package" ]] || continue

    if [[ "$kind" == "cask" ]]; then
      grep -qx "$package" <<< "$installed_casks" && installed_cask+=("$package") || missing_cask+=("$package")
    else
      grep -qx "$package" <<< "$installed_formulas" && installed_brew+=("$package") || missing_brew+=("$package")
    fi
  done < <(brewfile_entries)

  success "Installed brew formulas: ${#installed_brew[@]}"
  success "Installed casks: ${#installed_cask[@]}"
  [[ ${#missing_brew[@]} -gt 0 ]] && warn "Missing brew formulas: ${missing_brew[*]}"
  [[ ${#missing_cask[@]} -gt 0 ]] && warn "Missing casks: ${missing_cask[*]}"

  [[ ${#missing_brew[@]} -eq 0 && ${#missing_cask[@]} -eq 0 ]] && { success "All Brewfile packages are installed"; return 0; }
  return 1
}

# ═══════════════════════════════════════════════════════════════════════════════
# SYSTEM BOOTSTRAP
# ═══════════════════════════════════════════════════════════════════════════════

ensure_homebrew() {
  command_exists brew && { info "Homebrew already installed"; return 0; }

  if ! confirm "Homebrew is required. Install it now?"; then
    error "Homebrew is required for init"
    return 1
  fi

  step "Installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi

  success "Homebrew installed"
}

ensure_brew_package() {
  local package="$1" check_command="$2"

  command_exists "$check_command" && { info "$package already installed"; return 0; }

  if ! confirm "Install $package now?"; then
    error "$package is required for init"
    return 1
  fi

  step "Installing $package"
  run_logged --stream "brew install $package" brew install "$package"
  success "$package installed"
}

preflight_init() {
  ensure_homebrew
  ensure_brew_package stow stow
}

run_mise_install() {
  command_exists mise || { warn "mise is not installed; skipping runtime install"; return 0; }

  step "Installing mise-managed runtimes"
  run_logged "mise install" mise install
  success "mise runtimes installed"

  if command_exists corepack; then
    step "Enabling Corepack"
    run_logged "corepack enable" corepack enable && success "Corepack enabled" || warn "Failed to enable Corepack"
  fi
}

ensure_opencode() {
  command_exists opencode && { info "OpenCode already installed"; return 0; }

  if ! confirm "Install OpenCode now?"; then
    warn "Skipped OpenCode install"
    return 0
  fi

  step "Installing OpenCode"
  /bin/bash -c "$(curl -fsSL https://opencode.ai/install)" && success "OpenCode installed" || warn "Failed to install OpenCode"
}

setup_fish_shell() {
  command_exists fish || { warn "Fish is not installed; skipping default shell setup"; return 0; }

  local fish_path
  fish_path="$(command -v fish)"

  if ! grep -q "$fish_path" /etc/shells; then
    step "Registering Fish as a login shell"
    printf '%s\n' "$fish_path" | sudo tee -a /etc/shells >/dev/null && success "Fish added to /etc/shells" || { warn "Failed to add Fish to /etc/shells"; return 0; }
  fi

  [[ "${SHELL:-}" == "$fish_path" ]] && { success "Fish is already the default shell"; return 0; }

  step "Setting Fish as the default shell"
  chsh -s "$fish_path" && { success "Default shell changed to Fish"; detail "Log out and back in for the shell change to take effect"; } || warn "Failed to change default shell to Fish"
}

# ═══════════════════════════════════════════════════════════════════════════════
# STOW & SYMLINKS
# ═══════════════════════════════════════════════════════════════════════════════

symlink_points_to() {
  local path="$1" target_prefix="$2"
  [[ -L "$path" ]] || return 1
  [[ "$(readlink "$path" 2>/dev/null)" == *"$target_prefix"* ]]
}

emit_managed_targets() {
  local source_dir="$1" target_dir="$2" child_source

  while IFS= read -r child_source; do
    local name rel_path child_target
    name="$(basename "$child_source")"
    rel_path="${child_source#"$HOME_DIR"/}"
    child_target="$target_dir/$name"

    [[ -d "$child_source" ]] && [[ -z "$(find "$child_source" -mindepth 1 -maxdepth 1 -print -quit)" ]] && continue

    if [[ -d "$child_source" && -d "$child_target" && ! -L "$child_target" ]]; then
      emit_managed_targets "$child_source" "$child_target"
    else
      printf '%s\n' "$rel_path"
    fi
  done < <(find "$source_dir" -mindepth 1 -maxdepth 1 | LC_ALL=C sort)
}

managed_paths() {
  emit_managed_targets "$HOME_DIR" "$HOME"
}

check_managed_path() {
  local rel="$1" target_path="$HOME/$rel"

  symlink_points_to "$target_path" ".dotfiles/home" && return 0
  [[ -L "$target_path" ]] && { error "Symlink points outside dotfiles: $target_path"; return 1; }
  [[ -e "$target_path" ]] && { error "File exists, not a dotfiles symlink: $target_path"; return 1; }
  error "Missing: $target_path"
  return 1
}

run_stow() {
  local stow_args=(-R -d "$DOTFILES_DIR" -t "$HOME")
  if [[ "${1:-}" == "--dry-run" ]]; then
    stow_args=(-n -v "${stow_args[@]}")
    header "Dry Run Stow"
    detail "Previewing symlink changes"
    stow "${stow_args[@]}" home
  else
    header "Stow"
    detail "Applying managed files from $HOME_DIR"
    run_logged "stow" stow "${stow_args[@]}" home
    run_mise_install
  fi
  success "Dotfiles applied"
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMANDS
# ═══════════════════════════════════════════════════════════════════════════════

cmd_init() {
  header "Init"
  preflight_init
  success "Preflight ready"

  if ! confirm "Run brew bundle from $BREWFILE?"; then
    warn "Init cancelled"
    return 0
  fi

  run_brew_bundle
  ensure_opencode
  setup_fish_shell

  if ! confirm "Apply dotfiles with stow?"; then
    warn "Skipped stow"
    return 0
  fi

  run_stow
  success "Init complete"
}

cmd_doctor() {
  header "Doctor"

  local issues=0 tool

  [[ -d "$HOME_DIR" ]] && success "Found $HOME_DIR" || { error "Missing $HOME_DIR"; ((issues+=1)); }
  [[ -f "$BREWFILE" ]] && success "Found $BREWFILE" || { error "Missing $BREWFILE"; ((issues+=1)); }

  command_exists brew && success "Homebrew installed" || { error "Homebrew missing"; ((issues+=1)); }
  command_exists stow && success "GNU Stow installed" || { error "GNU Stow missing"; ((issues+=1)); }

  if command_exists fish; then
    success "Fish installed"
    [[ "${SHELL:-}" == "$(command -v fish)" ]] && success "Fish is the default shell" || warn "Fish is not the default shell"
  else
    warn "Fish is not installed"
  fi

  if [[ -f "$BREWFILE" ]] && command_exists brew; then
    step "Checking Brewfile compliance"
    brew bundle check --file "$BREWFILE" >/dev/null 2>&1 && success "Brewfile is satisfied" || { error "Brewfile packages are missing"; ((issues+=1)); }
  fi

  if [[ -d "$HOME_DIR" ]]; then
    step "Checking managed targets"
    while IFS= read -r source_path; do
      local rel="${source_path#"$HOME_DIR"/}"
      check_managed_path "$rel" || ((issues+=1))
    done < <(managed_paths)
  fi

  if [[ -f "$BREWFILE" ]] && command_exists brew; then
    step "Checking Brewfile package status"
    report_package_status || ((issues+=1))
  fi

  step "Checking link health"
  [[ -L "$HOME/.local/bin/dot" ]] && success "Found ~/.local/bin/dot symlink" || warn "Missing ~/.local/bin/dot symlink"

  local broken_links=0 link
  while IFS= read -r -d '' link; do
    [[ ! -e "$link" ]] && ((broken_links++))
  done < <(find "$HOME" -maxdepth 3 -type l -print0 2>/dev/null)

  [[ $broken_links -eq 0 ]] && success "No broken symlinks found under home" || warn "Found $broken_links broken symlink(s) under home"

  step "Checking core development tools"
  local optional_tools=(git gh jq rg mise opencode) optional_missing=()
  for tool in "${optional_tools[@]}"; do
    command_exists "$tool" && success "$tool is available" || optional_missing+=("$tool")
  done
  [[ ${#optional_missing[@]} -gt 0 ]] && warn "Missing optional tools: ${optional_missing[*]}"

  if command_exists mise; then
    step "Checking mise runtimes"
    mise ls >/dev/null 2>&1 && success "mise is responding" || warn "mise is installed but not responding correctly"
  fi

  step "Checking PATH exposure"
  case ":$PATH:" in
    *":$HOME/.local/bin:"*) success "~/.local/bin is in PATH" ;;
    *) warn "~/.local/bin is not in PATH" ;;
  esac

  step "Checking Fish completion link"
  local completion_target="$HOME/.config/fish/completions/dot.fish"
  [[ -L "$completion_target" ]] && success "Fish completion is linked" || \
    [[ -e "$completion_target" ]] && warn "Fish completion exists but is not a dotfiles symlink" || \
    warn "Fish completion is not installed"

  [[ $issues -eq 0 ]] && success "Doctor passed" || { error "Doctor found $issues issue(s)"; return 1; }
}

cmd_update() {
  require_runtime_tools brew stow git
  header "Update"

  if [[ -n "$(git -C "$DOTFILES_DIR" status --porcelain)" ]]; then
    warn "Dotfiles repo has local changes"
    if ! confirm "Continue with git pull anyway?"; then
      warn "Update cancelled"
      return 0
    fi
  fi

  step "Pulling latest changes"
  run_logged "git pull" git -C "$DOTFILES_DIR" pull
  success "Repository updated"

  if confirm "Run brew update, brew upgrade, and brew bundle?"; then
    step "Refreshing Homebrew"
    run_logged --stream "brew update" brew update
    run_logged --stream "brew upgrade" brew upgrade
    run_brew_bundle
    success "Package update complete"
  else
    warn "Skipped package update"
  fi

  if confirm "Re-apply dotfiles with stow?"; then
    run_stow
  else
    warn "Skipped stow"
  fi
}

cmd_gen_ssh_key() {
  header "Generate SSH Key"

  local email="${1:-}" domain key_name key_path backup_path

  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    cat <<'EOF'
dot gen-ssh-key - Generate an ed25519 SSH key

USAGE
  dot gen-ssh-key [email@example.com]
EOF
    return 0
  fi

  [[ -z "$email" ]] && read -r -p "Email for SSH key: " email
  [[ -z "$email" ]] && { error "Email is required"; return 1; }
  [[ "$email" != *@* ]] && { error "Invalid email: $email"; return 1; }

  domain="${email##*@}"
  domain="${domain%%.*}"
  domain="$(printf '%s' "$domain" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]_-')"
  [[ -n "$domain" ]] || domain="key"

  key_name="id_ed25519_${domain}"
  key_path="$HOME/.ssh/$key_name"

  detail "Target key: $key_path"

  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"

  if [[ -f "$key_path" ]]; then
    warn "SSH key already exists at $key_path"
    if ! confirm "Overwrite existing key?"; then
      warn "SSH key generation cancelled"
      return 0
    fi

    backup_path="${key_path}.backup.$(date +%Y%m%d_%H%M%S)"
    cp "$key_path" "$backup_path"
    [[ -f "${key_path}.pub" ]] && cp "${key_path}.pub" "${backup_path}.pub"
    success "Backed up existing key to $backup_path"
  fi

  step "Generating SSH key"
  ssh-keygen -t ed25519 -C "$email" -f "$key_path" -N "" || { error "Failed to generate SSH key"; return 1; }
  success "SSH key generated"

  step "Adding key to ssh-agent"
  pgrep -u "$USER" ssh-agent >/dev/null 2>&1 || eval "$(ssh-agent -s)" >/dev/null
  ssh-add "$key_path" >/dev/null 2>&1 && success "Key added to ssh-agent" || warn "Failed to add key to ssh-agent"

  if command_exists pbcopy; then
    pbcopy < "${key_path}.pub"
    success "Public key copied to clipboard"
  else
    warn "pbcopy not available; skipping clipboard copy"
  fi

  info "Public key: ${key_path}.pub"
  info "Add it to your Git host SSH keys settings"
}

cmd_check_packages() {
  require_runtime_tools brew
  header "Check Packages"
  report_package_status
}

cmd_package_help() {
  cat <<'EOF'
dot package - Manage Brewfile packages

USAGE
  dot package list
  dot package add <name> [brew|cask|auto]
  dot package remove <name>
  dot package update [name|all]
  dot package cleanup
EOF
}

cmd_package_list() {
  header "Package List"

  local kind package
  while IFS=$'\t' read -r kind package; do
    [[ -n "$kind" && -n "$package" ]] || continue
    printf '%s %s\n' "$kind" "$package"
  done < <(brewfile_entries)
}

cmd_package_add() {
  require_runtime_tools brew

  local package_name="${1:-}" package_type="${2:-auto}"

  [[ -z "$package_name" ]] && { error "Package name required"; cmd_package_help; return 1; }

  [[ "$package_type" == "auto" ]] && package_type=$(detect_package_type "$package_name")
  [[ "$package_type" != "brew" && "$package_type" != "cask" ]] && { error "Package type must be brew, cask, or auto"; return 1; }

  package_is_declared "$package_name" && { warn "$package_name is already declared in Brewfile"; return 0; }

  header "Add Package"
  step "Installing $package_name"
  [[ "$package_type" == "cask" ]] && brew install --cask "$package_name" || brew install "$package_name"

  step "Updating Brewfile"
  append_brewfile_entry "$package_type" "$package_name"
  success "Added $package_type package: $package_name"
}

cmd_package_remove() {
  require_runtime_tools brew

  local package_name="${1:-}"

  [[ -z "$package_name" ]] && { error "Package name required"; cmd_package_help; return 1; }

  package_is_declared "$package_name" || { warn "$package_name is not declared in Brewfile"; return 0; }

  header "Remove Package"
  step "Updating Brewfile"
  remove_brewfile_entry "$package_name"
  success "Removed $package_name from Brewfile"

  if confirm "Uninstall $package_name from this machine?"; then
    brew list --cask 2>/dev/null | grep -qx "$package_name" && brew uninstall --cask "$package_name" || warn "Failed to uninstall cask $package_name" || \
      brew uninstall "$package_name" || warn "Failed to uninstall formula $package_name"
  fi
}

cmd_package_update() {
  require_runtime_tools brew

  local package_name="${1:-all}"
  header "Update Packages"

  step "Refreshing Homebrew"
  brew update

  if [[ "$package_name" == "all" ]]; then
    step "Upgrading installed packages"
    brew upgrade
    success "Packages updated"
    return 0
  fi

  step "Upgrading $package_name"
  brew list --cask 2>/dev/null | grep -qx "$package_name" && brew upgrade --cask "$package_name" || brew upgrade "$package_name"
  success "$package_name updated"
}

cmd_package_cleanup() {
  require_runtime_tools brew
  header "Package Cleanup"
  brew cleanup
  brew autoremove
  success "Package cleanup complete"
}

cmd_package() {
  local subcommand="${1:-list}"
  shift || true

  case "$subcommand" in
    add) cmd_package_add "$@" ;;
    remove) cmd_package_remove "$@" ;;
    update) cmd_package_update "$@" ;;
    cleanup) cmd_package_cleanup ;;
    list) cmd_package_list "$@" ;;
    help|-h|--help) cmd_package_help ;;
    *) error "Unknown package subcommand: $subcommand"; cmd_package_help; return 1 ;;
  esac
}

cmd_edit() {
  local editor="${EDITOR:-cursor}"
  command -v "${editor%% *}" >/dev/null 2>&1 || { error "Editor not found: $editor"; return 1; }
  exec $editor "$DOTFILES_DIR"
}

cmd_completions() {
  local completions_dir="${HOME_DIR}/.config/fish/completions"
  local completions_file="${completions_dir}/dot.fish"

  header "Completions"

  mkdir -p "$completions_dir"

  cat > "$completions_file" <<'EOF'
# Fish completions for dot

complete -c dot -f

complete -c dot -n "__fish_use_subcommand" -a "init" -d "Bootstrap this machine from ~/.dotfiles"
complete -c dot -n "__fish_use_subcommand" -a "stow" -d "Apply managed dotfiles with GNU Stow"
complete -c dot -n "__fish_use_subcommand" -a "doctor" -d "Check core dotfiles health"
complete -c dot -n "__fish_use_subcommand" -a "update" -d "Pull repo changes, update packages, re-stow"
complete -c dot -n "__fish_use_subcommand" -a "gen-ssh-key" -d "Generate an SSH key for Git hosting"
complete -c dot -n "__fish_use_subcommand" -a "package" -d "Manage Brewfile packages"
complete -c dot -n "__fish_use_subcommand" -a "check-packages" -d "Check Brewfile packages against this machine"
complete -c dot -n "__fish_use_subcommand" -a "completions" -d "Generate Fish completions for dot"
complete -c dot -n "__fish_use_subcommand" -a "edit" -d "Open ~/.dotfiles in \$EDITOR"
complete -c dot -n "__fish_use_subcommand" -a "link" -d "Symlink ~/.dotfiles/dot into ~/.local/bin"
complete -c dot -n "__fish_use_subcommand" -a "unlink" -d "Remove ~/.local/bin/dot if it is a symlink"
complete -c dot -n "__fish_use_subcommand" -a "help" -d "Show help text"

complete -c dot -n "__fish_use_subcommand" -l yes -d "Skip confirmations"
complete -c dot -n "__fish_use_subcommand" -l version -d "Show version"
complete -c dot -n "__fish_use_subcommand" -s h -l help -d "Show help"

complete -c dot -n "__fish_seen_subcommand_from stow" -a "--dry-run" -d "Preview symlink changes"
complete -c dot -n "__fish_seen_subcommand_from package; and not __fish_seen_subcommand_from add remove update cleanup list help" -a "add remove update cleanup list help"
complete -c dot -n "__fish_seen_subcommand_from package; and __fish_seen_subcommand_from add" -a "brew cask auto"
complete -c dot -n "__fish_seen_subcommand_from package; and __fish_seen_subcommand_from update" -a "all"
EOF

  success "Generated $completions_file"
  detail "Apply dotfiles with 'dot stow' to install the completion"
}

cmd_link() {
  local target_dir="/usr/local/bin" link_path

  [[ -d "$target_dir" && -w "$target_dir" ]] || { target_dir="$HOME/.local/bin"; mkdir -p "$target_dir"; info "Using $target_dir"; }

  link_path="$target_dir/dot"

  [[ -e "$link_path" && ! -L "$link_path" ]] && { error "$link_path exists and is not a symlink"; return 1; }
  symlink_points_to "$link_path" "$DOTFILES_DIR/dot" && { success "Link already exists: $link_path"; return 0; }
  [[ -L "$link_path" ]] && rm "$link_path"

  ln -s "$DOTFILES_DIR/dot" "$link_path" && success "Linked $link_path -> $DOTFILES_DIR/dot" || { error "Failed to create $link_path"; return 1; }
}

cmd_unlink() {
  local link_path found=false paths=(
    "/usr/local/bin/dot" "$HOME/.local/bin/dot"
    "/usr/local/bin/dotfiles" "$HOME/.local/bin/dotfiles"
  )

  for link_path in "${paths[@]}"; do
    if symlink_points_to "$link_path" "$DOTFILES_DIR/dot"; then
      rm "$link_path"
      success "Removed $link_path"
      found=true
    elif [[ -L "$link_path" ]]; then
      warn "Skipped unrelated symlink: $link_path"
    fi
  done

  [[ "$found" == false ]] && info "No dot symlink found in known locations"
}

