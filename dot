#!/usr/bin/env bash

set -euo pipefail

readonly SCRIPT_NAME="dot"
readonly VERSION="0.1.0"
readonly DOTFILES_DIR="${HOME}/.dotfiles"
readonly HOME_DIR="${DOTFILES_DIR}/home"
readonly BREWFILE="${DOTFILES_DIR}/Brewfile"

ASSUME_YES=false

readonly RED=$'\033[0;31m'
readonly GREEN=$'\033[0;32m'
readonly YELLOW=$'\033[0;33m'
readonly BLUE=$'\033[0;34m'
readonly CYAN=$'\033[0;36m'
readonly BOLD=$'\033[1m'
readonly DIM=$'\033[2m'
readonly RESET=$'\033[0m'

info() {
  printf '%b\n' "${CYAN}ℹ${RESET} ${CYAN}[INFO]${RESET} $1"
}

warn() {
  printf '%b\n' "${YELLOW}⚠${RESET} ${YELLOW}[WARN]${RESET} $1" >&2
}

error() {
  printf '%b\n' "${RED}✗${RESET} ${RED}[ERROR]${RESET} $1" >&2
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

header() {
  printf '\n%b\n' "${BOLD}${BLUE}==>${RESET} ${BOLD}$1${RESET}"
}

step() {
  printf '%b\n' "${BOLD}${CYAN}->${RESET} $1"
}

detail() {
  printf '%b\n' "${DIM}  $1${RESET}"
}

success() {
  printf '%b\n' "${GREEN}✓${RESET} ${GREEN}[OK]${RESET} $1"
}

show_log_excerpt() {
  local log_file="$1"
  local line_count=0
  while IFS= read -r line; do
    line_count=$((line_count + 1))
    if (( line_count > 20 )); then
      break
    fi
    detail "$line"
  done < "$log_file"
}

run_logged() {
  local title="$1"
  shift

  local log_file
  log_file=$(mktemp)

  if "$@" >"$log_file" 2>&1; then
    rm -f "$log_file"
    return 0
  fi

  error "$title failed"
  if [[ -s "$log_file" ]]; then
    detail "Command output:"
    show_log_excerpt "$log_file"
  fi
  rm -f "$log_file"
  return 1
}

run_logged_streaming() {
  local title="$1"
  shift

  local log_file
  log_file=$(mktemp)

  detail "Running: $*"
  if "$@" 2>&1 | tee "$log_file"; then
    rm -f "$log_file"
    return 0
  fi

  error "$title failed"
  if [[ -s "$log_file" ]]; then
    detail "Command output:"
    show_log_excerpt "$log_file"
  fi
  rm -f "$log_file"
  return 1
}

confirm() {
  local prompt="$1"
  if [[ "$ASSUME_YES" == true ]]; then
    return 0
  fi
  read -r -p "$prompt [y/N]: " response
  case "$response" in
    [yY]|[yY][eE][sS]) return 0 ;;
    *) return 1 ;;
  esac
}

require_runtime_tools() {
  local missing=()
  local tool
  for tool in "$@"; do
    if ! command_exists "$tool"; then
      missing+=("$tool")
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    error "Missing required tools: ${missing[*]}"
    error "Run 'dot init' to repair this machine state."
    exit 1
  fi
}

ensure_homebrew() {
  if command_exists brew; then
    info "Homebrew already installed"
    return 0
  fi

  if ! confirm "Homebrew is required. Install it now?"; then
    error "Homebrew is required for init"
    return 1
  fi

  step "Installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi

  success "Homebrew installed"
}

ensure_brew_package() {
  local package="$1"
  local check_command="$2"

  if command_exists "$check_command"; then
    info "$package already installed"
    return 0
  fi

  if ! confirm "Install $package now?"; then
    error "$package is required for init"
    return 1
  fi

  step "Installing $package"
  run_logged_streaming "brew install $package" brew install "$package"
  success "$package installed"
}

preflight_init() {
  ensure_homebrew
  ensure_brew_package stow stow
}

show_help() {
  cat <<'EOF'
dot - Personal dotfiles manager

USAGE
  dot [--yes] <command> [options]

COMMANDS
  init            Bootstrap this machine from ~/.dotfiles
  stow            Apply managed dotfiles with GNU Stow
  doctor          Check core dotfiles health
  update          Pull repo changes, update packages, re-stow
  link            Symlink ~/.dotfiles/dot into ~/.local/bin
  unlink          Remove ~/.local/bin/dot if it is a symlink
  help            Show this help text

OPTIONS
  --yes           Skip confirmations
  --version       Show version
  -h, --help      Show help

STOW OPTIONS
  dot stow --dry-run
EOF
}

run_brew_bundle() {
  step "Applying Brewfile"
  detail "$BREWFILE"
  run_logged_streaming "brew bundle" brew bundle --file "$BREWFILE"
  success "Brewfile applied"
}

run_mise_install() {
  if ! command_exists mise; then
    warn "mise is not installed; skipping runtime install"
    return 0
  fi

  step "Installing mise-managed runtimes"
  run_logged "mise install" mise install
  success "mise runtimes installed"

  if command_exists corepack; then
    step "Enabling Corepack"
    if run_logged "corepack enable" corepack enable; then
      success "Corepack enabled"
    else
      warn "Failed to enable Corepack"
    fi
  fi
}

setup_fish_shell() {
  if ! command_exists fish; then
    warn "Fish is not installed; skipping default shell setup"
    return 0
  fi

  local fish_path
  fish_path="$(command -v fish)"

  if ! grep -q "$fish_path" /etc/shells; then
    step "Registering Fish as a login shell"
    if printf '%s\n' "$fish_path" | sudo tee -a /etc/shells >/dev/null; then
      success "Fish added to /etc/shells"
    else
      warn "Failed to add Fish to /etc/shells"
      return 0
    fi
  fi

  if [[ "${SHELL:-}" == "$fish_path" ]]; then
    success "Fish is already the default shell"
    return 0
  fi

  step "Setting Fish as the default shell"
  if chsh -s "$fish_path"; then
    success "Default shell changed to Fish"
    detail "Log out and back in for the shell change to take effect"
  else
    warn "Failed to change default shell to Fish"
  fi
}

run_stow() {
  local stow_args=(-R -d "$DOTFILES_DIR" -t "$HOME")
  if [[ "${1:-}" == "--dry-run" ]]; then
    stow_args=(-n -v "${stow_args[@]}")
    header "Dry Run Stow"
    detail "Previewing symlink changes"
  else
    header "Stow"
    detail "Applying managed files from $HOME_DIR"
  fi

  if [[ "${1:-}" == "--dry-run" ]]; then
    stow "${stow_args[@]}" home
  else
    run_logged "stow" stow "${stow_args[@]}" home
    run_mise_install
  fi
  success "Dotfiles applied"
}

cmd_init() {
  header "Init"
  preflight_init
  success "Preflight ready"

  if ! confirm "Run brew bundle from $BREWFILE?"; then
    warn "Init cancelled"
    return 0
  fi

  run_brew_bundle
  setup_fish_shell

  if ! confirm "Apply dotfiles with stow?"; then
    warn "Skipped stow"
    return 0
  fi

  run_stow
  success "Init complete"
}

path_is_managed_symlink() {
  local path="$1"
  [[ -L "$path" ]] || return 1

  local target
  target="$(readlink "$path" 2>/dev/null || true)"
  [[ "$target" == *".dotfiles/home"* ]]
}

emit_managed_targets() {
  local source_dir="$1"
  local target_dir="$2"
  local child_source

  while IFS= read -r child_source; do
    local name rel_path child_target
    name="$(basename "$child_source")"
    rel_path="${child_source#"$HOME_DIR"/}"
    child_target="$target_dir/$name"

    if [[ -d "$child_source" ]] && [[ -z "$(find "$child_source" -mindepth 1 -maxdepth 1 -print -quit)" ]]; then
      continue
    fi

    if [[ -d "$child_source" && -d "$child_target" && ! -L "$child_target" ]]; then
      emit_managed_targets "$child_source" "$child_target"
    else
      printf '%s\n' "$rel_path"
    fi
  done < <(find "$source_dir" -mindepth 1 -maxdepth 1 | LC_ALL=C sort)
}

managed_paths() {
  emit_managed_targets "$HOME_DIR" "$HOME"
}

check_managed_path() {
  local rel="$1"
  local target_path="$HOME/$rel"

  if path_is_managed_symlink "$target_path"; then
    return 0
  fi

  if [[ -L "$target_path" ]]; then
    error "Managed target points outside dotfiles: $target_path"
    return 1
  fi

  if [[ -e "$target_path" ]]; then
    error "Managed target exists but is not a dotfiles symlink: $target_path"
    return 1
  fi

  error "Missing managed target: $target_path"
  return 1
}

cmd_doctor() {
  require_runtime_tools brew stow
  header "Doctor"

  local issues=0

  if [[ -d "$HOME_DIR" ]]; then
    success "Found $HOME_DIR"
  else
    error "Missing $HOME_DIR"
    ((issues+=1))
  fi

  if [[ -f "$BREWFILE" ]]; then
    success "Found $BREWFILE"
  else
    error "Missing $BREWFILE"
    ((issues+=1))
  fi

  if command_exists brew; then
    success "Homebrew installed"
  else
    error "Homebrew missing"
    ((issues+=1))
  fi

  if command_exists stow; then
    success "GNU Stow installed"
  else
    error "GNU Stow missing"
    ((issues+=1))
  fi

  if [[ -f "$BREWFILE" ]]; then
    step "Checking Brewfile compliance"
    if brew bundle check --file "$BREWFILE" >/dev/null 2>&1; then
      success "Brewfile is satisfied"
    else
      error "Brewfile packages are missing"
      ((issues+=1))
    fi
  fi

  if [[ -d "$HOME_DIR" ]]; then
    step "Checking managed targets"
    while IFS= read -r source_path; do
      local rel
      rel="${source_path#"$HOME_DIR"/}"
      if ! check_managed_path "$rel"; then
        ((issues+=1))
      fi
    done < <(managed_paths)
  fi

  if [[ $issues -eq 0 ]]; then
    success "Doctor passed"
  else
    error "Doctor found $issues issue(s)"
    return 1
  fi
}

cmd_update() {
  require_runtime_tools brew stow git
  header "Update"

  if [[ -n "$(git -C "$DOTFILES_DIR" status --porcelain)" ]]; then
    warn "Dotfiles repo has local changes"
    if ! confirm "Continue with git pull anyway?"; then
      warn "Update cancelled"
      return 0
    fi
  fi

  step "Pulling latest changes"
  run_logged "git pull" git -C "$DOTFILES_DIR" pull
  success "Repository updated"

  if confirm "Run brew update, brew upgrade, and brew bundle?"; then
    step "Refreshing Homebrew"
    run_logged_streaming "brew update" brew update
    run_logged_streaming "brew upgrade" brew upgrade
    run_logged_streaming "brew bundle" brew bundle --file "$BREWFILE"
    success "Package update complete"
  else
    warn "Skipped package update"
  fi

  if confirm "Re-apply dotfiles with stow?"; then
    run_stow
  else
    warn "Skipped stow"
  fi
}

cmd_link() {
  mkdir -p "$HOME/.local/bin"

  local link_path="$HOME/.local/bin/dot"
  if [[ -L "$link_path" ]]; then
    rm "$link_path"
  fi

  if ln -s "$DOTFILES_DIR/dot" "$link_path"; then
    success "Linked $link_path -> $DOTFILES_DIR/dot"
  else
    error "Failed to create $link_path"
    return 1
  fi
}

cmd_unlink() {
  local link_path="$HOME/.local/bin/dot"
  if [[ -L "$link_path" ]]; then
    rm "$link_path"
    success "Removed $link_path"
  else
    info "No dot symlink found at $link_path"
  fi
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes)
        ASSUME_YES=true
        shift
        ;;
      --version)
        printf '%s %s\n' "$SCRIPT_NAME" "$VERSION"
        exit 0
        ;;
      -h|--help)
        show_help
        exit 0
        ;;
      *)
        break
        ;;
    esac
  done

  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)
      cmd_init "$@"
      ;;
    stow)
      require_runtime_tools stow
      run_stow "${1:-}"
      ;;
    doctor)
      cmd_doctor
      ;;
    update)
      cmd_update
      ;;
    link)
      cmd_link
      ;;
    unlink)
      cmd_unlink
      ;;
    help)
      show_help
      ;;
    *)
      error "Unknown command: $cmd"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
