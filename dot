# HELP & ENTRY POINT
# ═══════════════════════════════════════════════════════════════════════════════

show_help() {
  cat <<'EOF'
dot - Personal dotfiles manager

USAGE
  dot [--yes] <command> [options]

COMMANDS
  init            Bootstrap this machine from ~/.dotfiles
  stow            Apply managed dotfiles with GNU Stow
  doctor          Check core dotfiles health
  update          Pull repo changes, update packages, re-stow
  gen-ssh-key     Generate an SSH key for Git hosting
  package         Manage Brewfile packages
  check-packages  Check Brewfile packages against this machine
  completions     Generate Fish completions for dot
  edit            Open ~/.dotfiles in $EDITOR
  link            Symlink ~/.dotfiles/dot into ~/.local/bin
  unlink          Remove ~/.local/bin/dot if it is a symlink
  help            Show this help text

OPTIONS
  --yes           Skip confirmations
  --version       Show version
  -h, --help      Show help

STOW OPTIONS
  dot stow --dry-run

PACKAGE OPTIONS
  dot package list
  dot package add <name> [brew|cask|auto]
  dot package remove <name>
  dot package update [name|all]

SSH KEY OPTIONS
  dot gen-ssh-key [email@example.com]
EOF
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes) ASSUME_YES=true; shift ;;
      --version) printf '%s %s\n' "$SCRIPT_NAME" "$VERSION"; exit 0 ;;
      -h|--help) show_help; exit 0 ;;
      *) break ;;
    esac
  done

  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init) cmd_init "$@" ;;
    stow) require_runtime_tools stow; run_stow "${1:-}" ;;
    doctor) cmd_doctor ;;
    update) cmd_update ;;
    gen-ssh-key) cmd_gen_ssh_key "$@" ;;
    package) cmd_package "$@" ;;
    check-packages) cmd_check_packages ;;
    completions) cmd_completions ;;
    edit) cmd_edit ;;
    link) cmd_link ;;
    unlink) cmd_unlink ;;
    help) show_help ;;
    *) error "Unknown command: $cmd"; show_help; exit 1 ;;
  esac
}

main "$@"