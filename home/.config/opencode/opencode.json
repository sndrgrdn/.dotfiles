{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "opensrc": {
      "command": [
        "npx",
        "-y",
        "opensrc-mcp"
      ],
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*credentials:edit*": "deny",
      "git push*": "ask"
    },
    "external_directory": {
      "*": "ask",
      "/tmp/side-quest-*/**": "allow",
      "~/.agents/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.dotfiles/**": "allow",
      "~/.local/share/mise/**": "allow",
      "~/.local/share/opencode/**": "allow",
      "~/.local/share/opensrc/repos/**": "allow",
      "~/Developer/**": "allow"
    },
    "read": {
      "~/.ssh/**": "deny"
    }
  },
  "plugin": [
    "opencode-cursor-oauth@latest"
  ],
  "provider": {
    "cursor": {
      "name": "Cursor"
    }
  },
  "share": "manual",
  "snapshot": true
}
